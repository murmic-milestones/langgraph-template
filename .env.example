# Copy this file to .env and fill in your values.
OPENAI_API_KEY=sk-...

# Any chat model supported by langchain-openai.
MODEL_NAME=gpt-4o-mini

# Optional: LangSmith tracing (https://smith.langchain.com) — uncomment to
# get a full trace of every graph run, node, and LLM call.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=my-new-project
