# Copy this file to .env and fill in your values.
OPENAI_API_KEY=sk-...

# Any "provider:model" string accepted by init_chat_model. To switch
# providers, install the integration package and set the matching key,
# e.g.:  pip install langchain-anthropic
#        MODEL_NAME=anthropic:claude-sonnet-5  +  ANTHROPIC_API_KEY=...
MODEL_NAME=openai:gpt-4o-mini

# Optional: LangSmith tracing (https://smith.langchain.com) — uncomment to
# get a full trace of every graph run, node, and LLM call.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=my-new-project
