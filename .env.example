# Copy this file to .env and fill in your values.
OPENAI_API_KEY=sk-...

# MODEL_NAME is any "provider:model" string accepted by init_chat_model
# (a bare model name is treated as OpenAI). Supported out of the box —
# install the matching extra and set the matching key:
#
#   provider          install                          key
#   ---------------   ------------------------------   -----------------
#   openai            pip install -e "."               OPENAI_API_KEY
#   anthropic         pip install -e ".[anthropic]"    ANTHROPIC_API_KEY
#   google_genai      pip install -e ".[google]"       GOOGLE_API_KEY
#   ollama            pip install -e ".[ollama]"       (none — local server)
#
# Examples:
#   MODEL_NAME=anthropic:claude-sonnet-5
#   MODEL_NAME=google_genai:gemini-2.5-flash
#   MODEL_NAME=ollama:llama3.2        (needs `ollama serve` running locally)
MODEL_NAME=openai:gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Optional: LangSmith tracing (https://smith.langchain.com) — uncomment to
# get a full trace of every graph run, node, and LLM call.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=my-new-project
